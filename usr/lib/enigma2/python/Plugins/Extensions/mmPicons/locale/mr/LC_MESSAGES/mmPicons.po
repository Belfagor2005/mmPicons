msgid "Remove"
msgstr "काढा"

msgid "Restart"
msgstr "रीस्टार्ट करा"

msgid "SELECT YOUR CHOICE"
msgstr "तुमची निवड निवडा"

msgid "Save"
msgstr "जतन करा"

msgid "Select"
msgstr "निवडा"

msgid "Set the path to the Picons folder"
msgstr "Picons फोल्डरचा मार्ग सेट करा"

msgid "Successfully Picons Installed"
msgstr "पिकॉन्स यशस्वीरित्या स्थापित केले"

msgid "Successfully Skin Installed"
msgstr "त्वचा यशस्वीरित्या स्थापित केली"

msgid "Successfully saved configuration"
msgstr "कॉन्फिगरेशन यशस्वीरित्या सेव्ह केले"

msgid "Try again later ..."
msgstr "नंतर पुन्हा प्रयत्न करा..."

msgid "Update Aborted!"
msgstr "अद्यतन रद्द केले!"
