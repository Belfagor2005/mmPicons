msgstr "Enigma ကို ပြန်လည်စတင်လိုပါသလား။"

msgid "Download Failed!"
msgstr "ဒေါင်းလုဒ် မအောင်မြင်ပါ။"

msgid "Download Failed..."
msgstr "ဒေါင်းလုဒ် မအောင်မြင်ပါ..."

msgid "Download failed"
msgstr "ဒေါင်းလုဒ် မအောင်မြင်ပါ။"

