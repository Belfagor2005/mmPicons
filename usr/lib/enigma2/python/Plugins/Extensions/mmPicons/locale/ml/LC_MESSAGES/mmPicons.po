msgid "%s it has been cleaned"
msgstr "%s അത് വൃത്തിയാക്കി"

msgid "... please wait"
msgstr "... കാത്തിരിക്കൂ"

msgid ":P  COMING SOON!!!"
msgstr ":P ഉടൻ വരുന്നു!!!"

msgid "Back"
msgstr "തിരികെ"

msgid "Cancel"
msgstr "റദ്ദാക്കുക"

msgid "Cancel execution?"
msgstr "നിർവ്വഹണം റദ്ദാക്കണോ?"

msgid "Choice"
msgstr "ചോയ്സ്"

msgid "Choose Directory:"
msgstr "ഡയറക്ടറി തിരഞ്ഞെടുക്കുക:"

msgid "Choose directory"
msgstr "ഡയറക്ടറി തിരഞ്ഞെടുക്കുക"

msgid "Config"
msgstr "കോൺഫിഗറേഷൻ"

msgid "Congrats! You already have the latest version..."
msgstr "അഭിനന്ദനങ്ങൾ! നിങ്ങൾക്ക് ഇതിനകം ഏറ്റവും പുതിയ പതിപ്പുണ്ട്..."

msgid "Console"
msgstr "കൺസോൾ"

msgid "Device not detected!"
msgstr "ഉപകരണം കണ്ടെത്തിയില്ല!"

msgid "Do you want to install update ( %s ) now?"
msgstr "നിങ്ങൾക്ക് ഇപ്പോൾ അപ്ഡേറ്റ് (%s ) ഇൻസ്റ്റാൾ ചെയ്യണോ?"

msgid "Do you want to restart Enigma?"
msgstr "നിങ്ങൾക്ക് എനിഗ്മ പുനരാരംഭിക്കണോ?"

msgid "Download Failed!"
msgstr "ഡൗൺലോഡ് പരാജയപ്പെട്ടു!"

msgid "Download Failed..."
msgstr "ഡൗൺലോഡ് പരാജയപ്പെട്ടു..."

msgid "Download failed"
msgstr "ഡൗൺലോഡ് പരാജയപ്പെട്ടു"

msgid "Download in progress..."
msgstr "ഡൗൺലോഡ് പുരോഗമിക്കുന്നു..."

msgid "Erase %s... please wait"
msgstr "%s മായ്‌ക്കുക... ദയവായി കാത്തിരിക്കുക"

msgid "Exit"
msgstr "പുറത്ത്"

msgid "Hide/Show"
msgstr "മറയ്ക്കുക/കാണിക്കുക"

msgid "Install"
msgstr "ഇൻസ്റ്റാൾ ചെയ്യുക"

msgid "Install ..."
msgstr "ഇൻസ്റ്റാൾ ചെയ്യുക..."

msgid "Loading data... Please wait"
msgstr "ഡാറ്റ ലോഡുചെയ്യുന്നു... ദയവായി കാത്തിരിക്കുക"

msgid "Picons folder"
msgstr "Picons ഫോൾഡർ"

msgid "Please select ..."
msgstr "ദയവായി തിരഞ്ഞെടുക്കുക..."

msgid "Press Ok to select the folder containing the picons files"
msgstr "പിക്കോൺ ഫയലുകൾ അടങ്ങിയ ഫോൾഡർ തിരഞ്ഞെടുക്കാൻ ശരി അമർത്തുക"

msgid "Preview"
msgstr "പ്രിവ്യൂ"

msgid "Really close without saving the settings?"
msgstr "ക്രമീകരണങ്ങൾ സംരക്ഷിക്കാതെ ശരിക്കും അടയ്ക്കണോ?"

msgid "Remove"
msgstr "നീക്കം ചെയ്യുക"

msgid "Restart"
msgstr "പുനരാരംഭിക്കുക"

msgid "SELECT YOUR CHOICE"
msgstr "നിങ്ങളുടെ ചോയ്സ് തിരഞ്ഞെടുക്കുക"

msgid "Save"
msgstr "സംരക്ഷിക്കുക"

msgid "Select"
msgstr "തിരഞ്ഞെടുക്കുക"

msgid "Set the path to the Picons folder"
msgstr "Picons ഫോൾഡറിലേക്കുള്ള പാത സജ്ജമാക്കുക"

msgid "Successfully Picons Installed"
msgstr "Picons വിജയകരമായി ഇൻസ്റ്റാൾ ചെയ്തു"

msgid "Successfully Skin Installed"
msgstr "സ്കിൻ ഇൻസ്റ്റാൾ ചെയ്തു"

msgid "Successfully saved configuration"
msgstr "കോൺഫിഗറേഷൻ വിജയകരമായി സംരക്ഷിച്ചു"

msgid "Try again later ..."
msgstr "പിന്നീട് വീണ്ടും ശ്രമിക്കുക..."

msgid "Update Aborted!"
msgstr "അപ്‌ഡേറ്റ് നിർത്തലാക്കി!"
