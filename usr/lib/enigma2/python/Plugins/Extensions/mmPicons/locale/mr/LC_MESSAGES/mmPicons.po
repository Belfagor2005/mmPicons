msgid "%s it has been cleaned"
msgstr "%s ते साफ केले गेले आहे"

msgid "... please wait"
msgstr "... कृपया थांबा"

msgid ":P  COMING SOON!!!"
msgstr ":P लवकरच येत आहे!!!"

msgid "Back"
msgstr "मागे"

msgid "Cancel"
msgstr "रद्द करा"

msgid "Cancel execution?"
msgstr "अंमलबजावणी रद्द करायची?"

msgid "Choice"
msgstr "निवड"

msgid "Choose Directory:"
msgstr "निर्देशिका निवडा:"

msgid "Choose directory"
msgstr "निर्देशिका निवडा"

msgid "Config"
msgstr "कॉन्फिग"

msgid "Congrats! You already have the latest version..."
