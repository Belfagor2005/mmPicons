msgid "Erase %s... please wait"
msgstr "%s पुसून टाका... कृपया प्रतीक्षा करा"

msgid "Exit"
msgstr "बाहेर पडा"

msgid "Hide/Show"
msgstr "लपवा/दाखवा"

msgid "Install"
msgstr "स्थापित करा"

msgid "Install ..."
msgstr "स्थापित करा..."

msgid "Loading data... Please wait"
msgstr "डेटा लोड करत आहे... कृपया प्रतीक्षा करा"

