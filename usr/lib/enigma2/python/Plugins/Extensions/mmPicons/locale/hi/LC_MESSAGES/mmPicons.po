msgid "%s it has been cleaned"
msgstr "%s इसे साफ़ कर दिया गया है"

msgid "... please wait"
msgstr "... कृपया प्रतीक्षा करें"

msgid ":P  COMING SOON!!!"
msgstr ":P जल्द आ रहा है!!!"

msgid "Back"
msgstr "पीछे"

