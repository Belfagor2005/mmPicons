msgid "Picons folder"
msgstr "પિકોન્સ ફોલ્ડર"

msgid "Please select ..."
msgstr "કૃપા કરીને પસંદ કરો..."

msgid "Press Ok to select the folder containing the picons files"
msgstr "પીકોન્સ ફાઇલો ધરાવતું ફોલ્ડર પસંદ કરવા માટે ઓકે દબાવો"

msgid "Preview"
msgstr "પૂર્વાવલોકન"

msgid "Really close without saving the settings?"
msgstr "સેટિંગ્સ સાચવ્યા વિના ખરેખર બંધ કરીએ?"

msgid "Remove"
msgstr "દૂર કરો"

msgid "Restart"
msgstr "પુનઃપ્રારંભ કરો"

msgid "SELECT YOUR CHOICE"
msgstr "તમારી પસંદગી પસંદ કરો"

msgid "Save"
msgstr "સાચવો"

msgid "Select"
msgstr "પસંદ કરો"

msgid "Set the path to the Picons folder"
msgstr "Picons ફોલ્ડર માટે પાથ સેટ કરો"

msgid "Successfully Picons Installed"
msgstr "પિકોન્સ સફળતાપૂર્વક ઇન્સ્ટોલ થયા"

