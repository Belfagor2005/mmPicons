msgid "%s it has been cleaned"
msgstr "%s તે સાફ કરવામાં આવ્યું છે"

msgid "... please wait"
msgstr "... કૃપા કરીને રાહ જુઓ"

msgid ":P  COMING SOON!!!"
msgstr ":P ટૂંક સમયમાં આવી રહ્યું છે !!!"

msgid "Back"
msgstr "પાછળ"

msgid "Cancel"
msgstr "રદ કરો"

msgid "Cancel execution?"
msgstr "અમલ રદ કરીએ?"

msgid "Choice"
msgstr "પસંદગી"

msgid "Choose Directory:"
msgstr "ડિરેક્ટરી પસંદ કરો:"

msgid "Choose directory"
msgstr "ડિરેક્ટરી પસંદ કરો"

msgid "Config"
msgstr "રૂપરેખા"

msgid "Congrats! You already have the latest version..."
msgstr "અભિનંદન! તમારી પાસે પહેલેથી જ નવીનતમ સંસ્કરણ છે..."

