msgid "%s it has been cleaned"
msgstr "%s այն մաքրվել է"

msgid "... please wait"
msgstr "... խնդրում եմ սպասեք"

msgid ":P  COMING SOON!!!"
msgstr ":P ՇՈՒՏՈՎ!!!"

msgid "Back"
msgstr "Ետ"

msgid "Cancel"
msgstr "Չեղարկել"

msgid "Cancel execution?"
msgstr "Չեղարկե՞լ կատարումը:"

msgid "Choice"
msgstr "Ընտրություն"

msgid "Choose Directory:"
msgstr "Ընտրեք տեղեկատու."

msgid "Choose directory"
msgstr "Ընտրեք գրացուցակը"

msgid "Config"
msgstr "Կազմաձև"

msgid "Congrats! You already have the latest version..."
msgstr "Շնորհավորում եմ Դուք արդեն ունեք վերջին տարբերակը..."

msgid "Console"
msgstr "Վահանակ"

msgid "Device not detected!"
msgstr "Սարքը չի հայտնաբերվել:"

msgid "Do you want to install update ( %s ) now?"
msgstr "Ցանկանու՞մ եք տեղադրել թարմացում ( %s ) հիմա:"

msgid "Do you want to restart Enigma?"
msgstr "Ցանկանու՞մ եք վերագործարկել Enigma-ն:"

msgid "Download Failed!"
msgstr "Ներբեռնումը ձախողվեց:"

msgid "Download Failed..."
msgstr "Ներբեռնումը ձախողվեց..."

msgid "Download failed"
msgstr "Ներբեռնումը ձախողվեց"

msgid "Download in progress..."
msgstr "Ներբեռնումն ընթացքի մեջ է..."

msgid "Erase %s... please wait"
msgstr "Ջնջել %s... խնդրում ենք սպասել"

msgid "Exit"
msgstr "Ելք"

msgid "Hide/Show"
msgstr "Թաքցնել/Ցուցադրել"

msgid "Install"
msgstr "Տեղադրեք"

msgid "Install ..."
msgstr "Տեղադրեք..."

msgid "Loading data... Please wait"
msgstr "Տվյալների բեռնում... Խնդրում ենք սպասել"

msgid "Picons folder"
msgstr "Picons թղթապանակ"

msgid "Please select ..."
msgstr "Խնդրում ենք ընտրել..."

msgid "Press Ok to select the folder containing the picons files"
msgstr "Սեղմեք Ok՝ պիկոնների ֆայլերը պարունակող թղթապանակը ընտրելու համար"

msgid "Preview"
msgstr "Նախադիտում"

msgid "Really close without saving the settings?"
msgstr "Իսկապե՞ս փակել առանց կարգավորումները պահելու:"

msgid "Remove"
msgstr "Հեռացնել"

msgid "Restart"
msgstr "Վերագործարկեք"

msgid "SELECT YOUR CHOICE"
msgstr "ԸՆՏՐԵՔ ՁԵՐ ԸՆՏՐՈՒԹՅՈՒՆԸ"

msgid "Save"
msgstr "Պահպանել"

msgid "Select"
msgstr "Ընտրել"

msgid "Set the path to the Picons folder"
msgstr "Սահմանեք ուղին դեպի Picons թղթապանակ"

msgid "Successfully Picons Installed"
msgstr "Picon-ները հաջողությամբ տեղադրվեցին"

msgid "Successfully Skin Installed"
msgstr "Skin-ը հաջողությամբ տեղադրվեց"

msgid "Successfully saved configuration"
msgstr "Կազմաձևը հաջողությամբ պահպանվեց"

msgid "Try again later ..."
msgstr "Փորձեք ավելի ուշ…"

msgid "Update Aborted!"
msgstr "Թարմացումը ընդհատվեց:"
