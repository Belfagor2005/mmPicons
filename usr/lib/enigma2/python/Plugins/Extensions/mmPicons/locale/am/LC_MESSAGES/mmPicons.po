msgid "%s it has been cleaned"
msgstr "%s ተጠርጓል።"

msgid "... please wait"
msgstr "... እባክህ ጠብቅ"

msgid ":P  COMING SOON!!!"
msgstr ": P በቅርብ ቀን !!!"

msgid "Back"
msgstr "ተመለስ"

msgid "Cancel"
msgstr "ሰርዝ"

msgid "Cancel execution?"
msgstr "ማስፈጸሚያ ይሰረዝ?"

msgid "Choice"
msgstr "ምርጫ"

msgid "Choose Directory:"
msgstr "ማውጫ ይምረጡ፡-"

msgid "Choose directory"
msgstr "ማውጫ ይምረጡ"

msgid "Config"
msgstr "አዋቅር"

msgid "Congrats! You already have the latest version..."
msgstr "እንኳን ደስ ያለህ! ቀድሞውንም የቅርብ ጊዜ ስሪት አለህ..."

msgid "Console"
msgstr "ኮንሶል"

msgid "Device not detected!"
msgstr "መሣሪያ አልተገኘም!"

msgid "Do you want to install update ( %s ) now?"
msgstr "ማሻሻያ (%s) አሁን መጫን ይፈልጋሉ?"

msgid "Do you want to restart Enigma?"
msgstr "Enigma እንደገና ማስጀመር ይፈልጋሉ?"

msgid "Download Failed!"
msgstr "ማውረድ አልተሳካም!"

msgid "Download Failed..."
msgstr "ማውረድ አልተሳካም..."

msgid "Download failed"
msgstr "ማውረድ አልተሳካም።"

msgid "Download in progress..."
msgstr "ማውረድ በሂደት ላይ..."

msgid "Erase %s... please wait"
msgstr "%s ደምስስ... እባክዎ ይጠብቁ"

msgid "Exit"
msgstr "ውጣ"

msgid "Hide/Show"
msgstr "ደብቅ/ አሳይ"

msgid "Install"
msgstr "ጫን"

msgid "Install ..."
msgstr "ጫን..."

msgid "Loading data... Please wait"
msgstr "ውሂብ በመጫን ላይ... እባክዎ ይጠብቁ"

msgid "Picons folder"
msgstr "Picons አቃፊ"

msgid "Please select ..."
msgstr "እባክህ ምረጥ..."

msgid "Press Ok to select the folder containing the picons files"
msgstr "ፒኮን ፋይሎችን የያዘውን አቃፊ ለመምረጥ እሺን ይጫኑ"

msgid "Preview"
msgstr "ቅድመ እይታ"

msgid "Really close without saving the settings?"
msgstr "ቅንብሮቹን ሳታስቀምጥ በእርግጥ ይዘጋል?"

msgid "Remove"
msgstr "አስወግድ"

msgid "Restart"
msgstr "እንደገና ጀምር"

msgid "SELECT YOUR CHOICE"
msgstr "ምርጫዎን ይምረጡ"

msgid "Save"
msgstr "አስቀምጥ"

msgid "Select"
msgstr "ይምረጡ"

msgid "Set the path to the Picons folder"
msgstr "ወደ ፒኮንስ አቃፊ የሚወስደውን መንገድ ያዘጋጁ"

msgid "Successfully Picons Installed"
msgstr "በተሳካ ሁኔታ ፒኮኖች ተጭነዋል"

msgid "Successfully Skin Installed"
msgstr "በተሳካ ሁኔታ ቆዳ ተጭኗል"

msgid "Successfully saved configuration"
msgstr "ውቅር በተሳካ ሁኔታ ተቀምጧል"

msgid "Try again later ..."
msgstr "ቆይተው እንደገና ይሞክሩ..."

msgid "Update Aborted!"
msgstr "ዝማኔ ተቋርጧል!"
