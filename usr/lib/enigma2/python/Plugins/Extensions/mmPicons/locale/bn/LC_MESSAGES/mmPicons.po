msgid "%s it has been cleaned"
msgstr "%s এটা পরিষ্কার করা হয়েছে"

msgid "... please wait"
msgstr "... অনুগ্রহ করে অপেক্ষা করুন"

msgid ":P  COMING SOON!!!"
msgstr ":P শীঘ্রই আসছে!!!"

msgid "Back"
msgstr "ব্যাক"

msgid "Cancel"
msgstr "বাতিল করুন"

msgid "Cancel execution?"
msgstr "মৃত্যুদণ্ড বাতিল করবেন?"

msgid "Choice"
msgstr "পছন্দ"

msgid "Choose Directory:"
msgstr "ডিরেক্টরি নির্বাচন করুন:"

msgid "Choose directory"
msgstr "ডিরেক্টরি নির্বাচন করুন"

msgid "Config"
msgstr "কনফিগার"

msgid "Congrats! You already have the latest version..."
msgstr "অভিনন্দন! আপনার কাছে ইতিমধ্যেই সর্বশেষ সংস্করণ আছে..."

msgid "Console"
msgstr "কনসোল"

msgid "Device not detected!"
msgstr "ডিভাইস সনাক্ত করা হয়নি!"

msgid "Do you want to install update ( %s ) now?"
msgstr "আপনি কি এখন আপডেট (%s) ইনস্টল করতে চান?"

msgid "Do you want to restart Enigma?"
msgstr "আপনি Enigma পুনরায় চালু করতে চান?"

msgid "Download Failed!"
msgstr "ডাউনলোড ব্যর্থ হয়েছে!"

msgid "Download Failed..."
msgstr "ডাউনলোড ব্যর্থ হয়েছে..."

msgid "Download failed"
msgstr "ডাউনলোড ব্যর্থ হয়েছে৷"

msgid "Download in progress..."
msgstr "ডাউনলোড চলছে..."

msgid "Erase %s... please wait"
msgstr "%s মুছুন... অনুগ্রহ করে অপেক্ষা করুন"

msgid "Exit"
msgstr "প্রস্থান করুন"

msgid "Hide/Show"
msgstr "লুকান/দেখান"

msgid "Install"
msgstr "ইনস্টল করুন"

msgid "Install ..."
msgstr "ইনস্টল করুন..."

msgid "Loading data... Please wait"
msgstr "ডেটা লোড হচ্ছে... অনুগ্রহ করে অপেক্ষা করুন"

msgid "Picons folder"
msgstr "পিকন ফোল্ডার"

msgid "Please select ..."
msgstr "অনুগ্রহ করে নির্বাচন করুন..."

msgid "Press Ok to select the folder containing the picons files"
msgstr "পিকন ফাইল ধারণকারী ফোল্ডার নির্বাচন করতে ওকে টিপুন"

msgid "Preview"
msgstr "পূর্বরূপ"

msgid "Really close without saving the settings?"
msgstr "সেটিংস সংরক্ষণ ছাড়া সত্যিই বন্ধ?"

msgid "Remove"
msgstr "সরান"

msgid "Restart"
msgstr "রিস্টার্ট করুন"

msgid "SELECT YOUR CHOICE"
msgstr "আপনার পছন্দ নির্বাচন করুন"

msgid "Save"
msgstr "সংরক্ষণ করুন"

msgid "Select"
msgstr "নির্বাচন করুন"

msgid "Set the path to the Picons folder"
msgstr "Picons ফোল্ডারে পাথ সেট করুন"

msgid "Successfully Picons Installed"
msgstr "সফলভাবে পিকন ইনস্টল করা হয়েছে৷"

msgid "Successfully Skin Installed"
msgstr "সফলভাবে চামড়া ইনস্টল করা হয়েছে"

msgid "Successfully saved configuration"
msgstr "কনফিগারেশন সফলভাবে সংরক্ষিত হয়েছে"

msgid "Try again later ..."
msgstr "পরে আবার চেষ্টা করুন..."

msgid "Update Aborted!"
msgstr "আপডেট বাতিল করা হয়েছে!"
