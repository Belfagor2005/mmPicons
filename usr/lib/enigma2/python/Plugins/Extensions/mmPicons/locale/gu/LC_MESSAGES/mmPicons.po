msgid "Do you want to restart Enigma?"
msgstr "શું તમે Enigma પુનઃપ્રારંભ કરવા માંગો છો?"

msgid "Download Failed!"
msgstr "ડાઉનલોડ નિષ્ફળ થયું!"

msgid "Download Failed..."
