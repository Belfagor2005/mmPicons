msgstr "... ကျေးဇူးပြုပြီးခဏစောင့်ပါ"

msgid ":P  COMING SOON!!!"
msgstr ":P မကြာမီလာမည်!!!"

msgid "Back"
msgstr "ကျော"

msgid "Cancel"
msgstr "မလုပ်တော့"

msgid "Cancel execution?"
msgstr "လုပ်ဆောင်မှုကို ပယ်ဖျက်မလား။"

msgid "Choice"
msgstr "ရွေးချယ်မှု"

msgid "Choose Directory:"
msgstr "လမ်းညွှန်ကို ရွေးပါ-"

msgid "Choose directory"
msgstr "လမ်းညွှန်ကို ရွေးပါ။"

msgid "Config"
msgstr "ပြင်ဆင်မှု"

msgid "Congrats! You already have the latest version..."
msgstr "ဂုဏ်ပြုပါသည်။ သင့်တွင် နောက်ဆုံးထွက်ဗားရှင်းရှိနေပြီဖြစ်သည်။"

msgid "Console"
msgstr "ဖြေသိမ့်"

