msgstr "ત્વચા સફળતાપૂર્વક સ્થાપિત"

msgid "Successfully saved configuration"
msgstr "ગોઠવણી સફળતાપૂર્વક સાચવી"

msgid "Try again later ..."
msgstr "પછીથી ફરી પ્રયાસ કરો..."

msgid "Update Aborted!"
msgstr "અપડેટ રદ કર્યું!"
